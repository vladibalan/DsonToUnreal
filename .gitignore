# Unreal Engine generated — never commit
Binaries/
Intermediate/
Saved/

# Rider generated
.idea/
*.DotSettings.user

# Visual Studio generated
.vs/
*.VC.db
*.VC.opendb

# UBT generated solution files — regenerated on demand
*.sln
*.suo

# OS
Thumbs.db
.DS_Store

# clangd language server — generated locally, never commit.
# (A committed .clangd *config* is fine; these are machine-specific outputs:
#  compile_commands.json holds absolute D:/ paths, .cache/ is clangd's index.)
compile_commands.json
.cache/

# ---- Agent handoff scratch (Director <-> Implementer task/feedback files) ----
# Per-task task-<id>.md / feedback-<id>.md live here during a run and move to
# .handoff/history/ on close. Local-only workflow scratch: never tracked, kept out
# of the git diff the Director verifies against and out of agent discovery
# (see AGENTS.md Generated Folders and Docs/AgentWorkflow.md).
.handoff/

# -------------------------------------------------------
# ThirdParty binaries — commit these (precompiled DsonParser)
# -------------------------------------------------------
# The rules above do not affect ThirdParty since none of
# the patterns match it. Explicitly document what IS committed:
#
# Source/ThirdParty/DsonParser/Include/DsonParserAPI.h  ← committed
# Source/ThirdParty/DsonParser/Libs/Win64/DsonParser.dll ← committed
# Source/ThirdParty/DsonParser/Libs/Win64/DsonParser.lib ← committed
#
# If you switch to Git LFS for binaries, add:
# *.dll filter=lfs diff=lfs merge=lfs -text
# *.lib filter=lfs diff=lfs merge=lfs -text
# *.pdb filter=lfs diff=lfs merge=lfs -text